generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BenchUser {
  id    Int         @id @default(autoincrement())
  name  String
  email String
  posts BenchPost[]

  @@map("bench_users")
}

model BenchPost {
  id       Int       @id @default(autoincrement())
  title    String
  body     String
  authorId Int       @map("author_id")
  author   BenchUser @relation(fields: [authorId], references: [id])

  @@map("bench_posts")
}
