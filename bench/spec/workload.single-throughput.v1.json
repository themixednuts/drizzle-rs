{
  "version": "v1",
  "suite": "throughput-http",
  "name": "Single Endpoint Throughput",
  "load": {
    "kind": "closed",
    "executor": "constant-vus",
    "unit": "1s",
    "concurrency": 512
  },
  "data": {
    "name": "bench",
    "seed": 42,
    "schema": "bench/schema.sql"
  },
  "shape": {
    "mode": "single",
    "endpoint": "/customer-by-id"
  },
  "stages": [
    { "sec": 60, "vus": 512 }
  ],
  "requests": {
    "source": "generated",
    "file": "bench/spec/requests.empty.v1.json",
    "skip": []
  },
  "pacing": {
    "mode": "none"
  },
  "sampling": {
    "cpu_ms": 200,
    "bucket_s": 1
  },
  "limits": {
    "err": 0.01,
    "p95": null
  }
}
