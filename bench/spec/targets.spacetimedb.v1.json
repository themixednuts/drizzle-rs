[
  {
    "version": "v1",
    "id": "spacetime-pgwire-rs",
    "display": {
      "name": "SpacetimeDB PGWire",
      "description": "SpacetimeDB PGWire target using a tokio-postgres simple-query client pool. PGWire supports a narrower SQL surface, so unsupported query shapes are implemented in the target process while preserving the same HTTP contract."
    },
    "group": "spacetimedb",
    "lang": "rust",
    "runtime": {
      "name": "rust",
      "ver": "1.95.0"
    },
    "orm": {
      "name": "none",
      "ver": "0"
    },
    "driver": {
      "name": "tokio-postgres-simple",
      "ver": "0.7.17"
    },
    "proc": {
      "mode": "single",
      "workers": 1
    },
    "pool": {
      "max": 4,
      "min": 1,
      "acquire_ms": 50
    },
    "db": {
      "profile": "spacetimedb-pgwire",
      "hash": "sha256:7bd4286ec47f86445e5ef9f6cc6357a27974cb8313766444fa5cbeff8eb83d43"
    },
    "wire": {
      "format": "text"
    },
    "fair": {
      "workers": 1,
      "pool": 4,
      "db": "spacetimedb",
      "schema": "sha256:67d569fc52dca6de6f2747867f2e7abe8f4cc736f2c2454f9da5f6e78901759d",
      "contract": "v1"
    },
    "contract": {
      "ver": "v1"
    },
    "parity": {
      "cmd": ["cargo", "run", "-q", "--release", "-p", "bench-runner", "--", "parity"]
    },
    "load": {
      "cmd": ["cargo", "run", "-q", "--release", "-p", "bench-runner", "--", "load"]
    }
  }
]
