{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bench.drizzle.rs/schema/run-manifest.v1.schema.json",
  "title": "Run Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "run_id",
    "suite",
    "git",
    "workload",
    "targets",
    "start",
    "end",
    "status",
    "seed",
    "load",
    "dataset",
    "artifacts",
    "runner",
    "trials"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z_[a-f0-9]{7,40}_[a-z0-9-]+$"
    },
    "suite": {
      "type": "string",
      "enum": [
        "throughput-http",
        "mvcc-contention"
      ]
    },
    "git": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "workload": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "start": {
      "type": "string",
      "format": "date-time"
    },
    "end": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "canceled",
        "partial"
      ]
    },
    "seed": {
      "type": "integer",
      "minimum": 0
    },
    "load": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executor", "stages", "duration_s", "max_vus", "requests"],
      "properties": {
        "executor": { "type": "string", "minLength": 1 },
        "stages": { "type": "integer", "minimum": 1 },
        "duration_s": { "type": "integer", "minimum": 1 },
        "max_vus": { "type": "integer", "minimum": 1 },
        "requests": { "type": "integer", "minimum": 0 }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["customers", "employees", "orders", "suppliers", "products", "details_per_order"],
      "properties": {
        "customers": { "type": "integer", "minimum": 0 },
        "employees": { "type": "integer", "minimum": 0 },
        "orders": { "type": "integer", "minimum": 0 },
        "suppliers": { "type": "integer", "minimum": 0 },
        "products": { "type": "integer", "minimum": 0 },
        "details_per_order": { "type": "integer", "minimum": 0 }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base",
        "sums"
      ],
      "properties": {
        "base": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "report": {
          "type": "string",
          "minLength": 1
        },
        "sums": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "os",
        "cpu",
        "cores",
        "mem_gb",
        "headroom"
      ],
      "properties": {
        "class": {
          "type": "string",
          "minLength": 1
        },
        "os": {
          "type": "string",
          "minLength": 1
        },
        "cpu": {
          "type": "string",
          "minLength": 1
        },
        "cores": {
          "type": "integer",
          "minimum": 1
        },
        "mem_gb": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "headroom": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cpu_peak",
            "net_peak"
          ],
          "properties": {
            "cpu_peak": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "net_peak": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        }
      }
    },
    "trials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count",
        "aggregate"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "aggregate": {
          "type": "string",
          "enum": [
            "median",
            "mean"
          ]
        }
      }
    },
    "compat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workload",
        "class",
        "targets"
      ],
      "properties": {
        "workload": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "class": {
          "type": "string",
          "minLength": 1
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        }
      }
    }
  }
}
