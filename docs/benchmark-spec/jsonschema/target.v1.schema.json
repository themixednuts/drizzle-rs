{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bench.drizzle.rs/schema/target.v1.schema.json",
  "title": "Target v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "lang",
    "runtime",
    "orm",
    "driver",
    "proc",
    "pool",
    "db",
    "wire",
    "fair",
    "contract"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "lang": {
      "type": "string",
      "enum": [
        "ts",
        "go",
        "rust",
        "other"
      ]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "ver"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ver": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "orm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "ver"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ver": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "driver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "ver"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ver": {
          "type": "string",
          "minLength": 1
        },
        "transport": {
          "type": "string"
        }
      }
    },
    "proc": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "workers"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "single",
            "multi"
          ]
        },
        "workers": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "pool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max"
      ],
      "properties": {
        "max": {
          "type": "integer",
          "minimum": 1
        },
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "acquire_ms": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "db": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "hash"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "wire": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format"
      ],
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "json",
            "text",
            "binary",
            "bsatn"
          ]
        }
      }
    },
    "fair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workers",
        "pool",
        "db",
        "schema",
        "contract"
      ],
      "properties": {
        "workers": {
          "type": "integer",
          "minimum": 1
        },
        "pool": {
          "type": "integer",
          "minimum": 1
        },
        "db": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "contract": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ver"
      ],
      "properties": {
        "ver": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "parity": {
      "$ref": "#/$defs/exec"
    },
    "warmup": {
      "$ref": "#/$defs/exec"
    },
    "load": {
      "$ref": "#/$defs/exec"
    },
    "server": {
      "$ref": "#/$defs/exec"
    },
    "group": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "exec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cmd"
      ],
      "properties": {
        "cmd": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "timeout_s": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
