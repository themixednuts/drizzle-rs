{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bench.drizzle.rs/schema/summary.v1.schema.json",
  "title": "Summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "run_id",
    "suite",
    "target_id",
    "primary",
    "spread",
    "saturation"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z_[a-f0-9]{7,40}_[a-z0-9-]+$"
    },
    "suite": {
      "type": "string",
      "enum": [
        "throughput-http",
        "mvcc-contention"
      ]
    },
    "target_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "group": {
      "type": "string",
      "minLength": 1
    },
    "primary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rps",
        "latency",
        "cpu",
        "err"
      ],
      "properties": {
        "rps": {
          "$ref": "#/$defs/avg_peak"
        },
        "latency": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "avg",
            "p90",
            "p95",
            "p99",
            "p999"
          ],
          "properties": {
            "avg": {
              "type": "number",
              "minimum": 0
            },
            "p90": {
              "type": "number",
              "minimum": 0
            },
            "p95": {
              "type": "number",
              "minimum": 0
            },
            "p99": {
              "type": "number",
              "minimum": 0
            },
            "p999": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "cpu": {
          "$ref": "#/$defs/avg_peak"
        },
        "mem": {
          "$ref": "#/$defs/avg_peak"
        },
        "err": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "spread": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trials",
        "aggregate",
        "rps",
        "p95",
        "variance"
      ],
      "properties": {
        "trials": {
          "type": "integer",
          "minimum": 1
        },
        "aggregate": {
          "type": "string",
          "enum": [
            "median",
            "mean"
          ]
        },
        "rps": {
          "$ref": "#/$defs/range"
        },
        "p95": {
          "$ref": "#/$defs/range"
        },
        "variance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rps",
            "p95",
            "cpu",
            "err"
          ],
          "properties": {
            "rps": {
              "$ref": "#/$defs/variance_metric"
            },
            "p95": {
              "$ref": "#/$defs/variance_metric"
            },
            "cpu": {
              "$ref": "#/$defs/variance_metric"
            },
            "mem": {
              "$ref": "#/$defs/variance_metric"
            },
            "err": {
              "$ref": "#/$defs/variance_metric"
            }
          }
        },
        "boxplot": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rps",
            "p95",
            "cpu",
            "err"
          ],
          "properties": {
            "rps": {
              "$ref": "#/$defs/box_metric"
            },
            "p95": {
              "$ref": "#/$defs/box_metric"
            },
            "cpu": {
              "$ref": "#/$defs/box_metric"
            },
            "mem": {
              "$ref": "#/$defs/box_metric"
            },
            "err": {
              "$ref": "#/$defs/box_metric"
            }
          }
        },
        "ci95": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "rps": {
              "$ref": "#/$defs/range"
            },
            "p95": {
              "$ref": "#/$defs/range"
            }
          }
        }
      }
    },
    "saturation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "knee_rps",
        "knee_p95"
      ],
      "properties": {
        "knee_rps": {
          "type": "number",
          "minimum": 0
        },
        "knee_p95": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "avg_peak": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "avg",
        "peak"
      ],
      "properties": {
        "avg": {
          "type": "number",
          "minimum": 0
        },
        "peak": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      }
    },
    "box_metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "q1",
        "median",
        "q3",
        "max",
        "samples"
      ],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0
        },
        "q1": {
          "type": "number",
          "minimum": 0
        },
        "median": {
          "type": "number",
          "minimum": 0
        },
        "q3": {
          "type": "number",
          "minimum": 0
        },
        "max": {
          "type": "number",
          "minimum": 0
        },
        "samples": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "variance_metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "stdev",
        "samples"
      ],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0
        },
        "stdev": {
          "type": "number",
          "minimum": 0
        },
        "samples": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
