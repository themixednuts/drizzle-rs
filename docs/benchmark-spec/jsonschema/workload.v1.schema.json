{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bench.drizzle.rs/schema/workload.v1.schema.json",
  "title": "Workload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "suite",
    "load",
    "data",
    "shape",
    "stages",
    "requests",
    "sampling",
    "limits"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "suite": {
      "type": "string",
      "enum": [
        "throughput-http",
        "mvcc-contention"
      ]
    },
    "load": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "executor",
        "unit",
        "concurrency"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "open",
            "closed"
          ]
        },
        "executor": {
          "type": "string",
          "enum": [
            "constant-arrival-rate",
            "ramping-arrival-rate",
            "ramping-vus",
            "constant-vus"
          ]
        },
        "unit": {
          "type": "string",
          "pattern": "^[0-9]+(ms|s|m)$"
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "seed",
        "schema"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "schema": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "shape": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "endpoint"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "mixed",
            "single"
          ]
        },
        "endpoint": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "single"
              }
            }
          },
          "then": {
            "properties": {
              "endpoint": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "mixed"
              }
            }
          },
          "then": {
            "properties": {
              "endpoint": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sec"
        ],
        "properties": {
          "sec": {
            "type": "integer",
            "minimum": 1
          },
          "vus": {
            "type": "integer",
            "minimum": 1
          },
          "rps": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        },
        "oneOf": [
          {
            "required": [
              "vus"
            ]
          },
          {
            "required": [
              "rps"
            ]
          }
        ]
      }
    },
    "requests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "file",
        "skip"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "generated",
            "file"
          ]
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "skip": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu_ms",
        "bucket_s"
      ],
      "properties": {
        "cpu_ms": {
          "type": "integer",
          "minimum": 50
        },
        "bucket_s": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "err"
      ],
      "properties": {
        "err": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "p95": {
          "type": ["number", "null"],
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
