{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bench.drizzle.rs/schema/timeseries.v1.schema.json",
  "title": "Timeseries v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "run_id",
    "suite",
    "target_id",
    "interval_s",
    "points"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z_[a-f0-9]{7,40}_[a-z0-9-]+$"
    },
    "suite": {
      "type": "string",
      "enum": [
        "throughput-http",
        "mvcc-contention"
      ]
    },
    "target_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "interval_s": {
      "type": "integer",
      "minimum": 1
    },
    "points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "time",
          "rps",
          "err",
          "latency",
          "cpu"
        ],
        "properties": {
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "rps": {
            "type": "number",
            "minimum": 0
          },
          "err": {
            "type": "number",
            "minimum": 0
          },
          "latency": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "avg",
              "p95",
              "p99"
            ],
            "properties": {
              "avg": {
                "type": "number",
                "minimum": 0
              },
              "p95": {
                "type": "number",
                "minimum": 0
              },
              "p99": {
                "type": "number",
                "minimum": 0
              },
              "p999": {
                "type": "number",
                "minimum": 0
              }
            }
          },
          "cpu": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          "mem_mb": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    }
  }
}
